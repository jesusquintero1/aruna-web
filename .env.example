# ============================================================
# ARUVIA · Variables de entorno
# Copia este archivo como `.env.local` y rellena los valores.
# .env.local NO se sube a git.
# ============================================================

# --- Supabase (Settings → API en tu proyecto Supabase) ---
# La app usa la SERVICE ROLE (omite RLS). Es secreta: rótala si se filtra.
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- Autenticación del admin ---
# OBLIGATORIA en producción: sin AUTH_SECRET la app FALLA (no usa secreto por
# defecto, para que nadie pueda forjar una sesión de admin). Genera uno fuerte:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=cambia-esto-por-un-secreto-largo-aleatorio

# Credenciales del primer admin (se siembran con `npm run seed:admin`).
# El login por estas variables SOLO funciona en desarrollo sin Supabase;
# en producción la autenticación exige la tabla admin_users.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esta-contrasena

# --- Pasarela de pago: Mercado Pago (Checkout Pro) ---
# Credenciales en: mercadopago.com.co/developers → tu app → Credenciales.
# Usa las de PRUEBA (sandbox) para testear; las de PRODUCCIÓN para vender.
MP_ACCESS_TOKEN=APP_USR-...        # secreto (servidor). NO exponer en el navegador.
MP_PUBLIC_KEY=APP_USR-...          # público (frontend)
MP_WEBHOOK_SECRET=                 # firma del webhook (MP → Webhooks → clave secreta)

# URL pública del sitio (back_urls y notification_url de Mercado Pago)
NEXT_PUBLIC_SITE_URL=https://aruvia.com.co

# --- Correos transaccionales (Resend) ---
# Crea cuenta en resend.com (gratis) CON el correo del negocio (aruviastore@gmail.com)
# y crea una API key. Con el dominio aruvia.com.co verificado en Resend, se envía a
# clientes desde @aruvia.com.co; sin verificar, solo a la dirección dueña de la cuenta.
RESEND_API_KEY=re_...
# Remitente. Con el dominio verificado: ARÜVIA <hola@aruvia.com.co>.
EMAIL_FROM=ARÜVIA <hola@aruvia.com.co>
# Correo del negocio donde llega la alerta de cada venta.
ADMIN_EMAIL=aruviastore@gmail.com

# --- Notificaciones push de pedidos (Web Push / VAPID) ---
# Genera el par de llaves con: npx web-push generate-vapid-keys
# La pública va también como NEXT_PUBLIC_ (se usa en el cliente).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:aruviastore@gmail.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
