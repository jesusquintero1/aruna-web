# ============================================================
# ARUNA · Variables de entorno
# Copia este archivo como `.env.local` y rellena los valores.
# .env.local NO se sube a git.
# ============================================================

# --- Supabase (Settings → API en tu proyecto Supabase) ---
# La app usa la SERVICE ROLE (omite RLS). Es secreta: rótala si se filtra.
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- Autenticación del admin ---
# OBLIGATORIA en producción: sin AUTH_SECRET la app FALLA (no usa secreto por
# defecto, para que nadie pueda forjar una sesión de admin). Genera uno fuerte:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=cambia-esto-por-un-secreto-largo-aleatorio

# Credenciales del primer admin (se siembran con `npm run seed:admin`).
# El login por estas variables SOLO funciona en desarrollo sin Supabase;
# en producción la autenticación exige la tabla admin_users.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esta-contrasena

# --- Pasarela de pago Wompi (opcional, fase posterior) ---
# WOMPI_PUBLIC_KEY=
# WOMPI_PRIVATE_KEY=
# WOMPI_EVENTS_SECRET=
